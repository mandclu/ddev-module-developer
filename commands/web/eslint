#!/usr/bin/env bash
#ddev-generated

## Description: Run ESLint for JS and YAML validation with Prettier (Drupal standards)
## Usage: eslint [flags] [path]
## Example: "ddev eslint web/modules/custom/mymodule/js"
## ExecRaw: true
## HostWorkingDir: true

# Priority 1: project-level ESLint config at the project root.
for config in .eslintrc .eslintrc.json .eslintrc.yaml .eslintrc.yml \
              .eslintrc.js .eslintrc.cjs eslint.config.js eslint.config.cjs; do
  if [ -f "${DDEV_APPROOT}/${config}" ]; then
    exec eslint "$@"
  fi
done

# For priorities 2 and 3, temporarily copy Drupal core's .prettierrc.json
# and a .prettierignore into any directory argument so that Prettier rules
# resolve consistently even for code outside the core tree.
CORE_PRETTIERRC="${DDEV_APPROOT}/${DDEV_DOCROOT}/core/.prettierrc.json"
PRETTIER_TARGET=""
for arg in "$@"; do
  if [ -d "${arg}" ]; then
    PRETTIER_TARGET="${arg}"
    break
  fi
done
if [ -n "${PRETTIER_TARGET}" ] && [ -f "${CORE_PRETTIERRC}" ]; then
  cp "${CORE_PRETTIERRC}" "${PRETTIER_TARGET}/.prettierrc.json"
  printf '*.yml\n' > "${PRETTIER_TARGET}/.prettierignore"
  trap 'rm -f "${PRETTIER_TARGET}/.prettierrc.json" "${PRETTIER_TARGET}/.prettierignore"' EXIT
fi

# Priority 2: Drupal core's .eslintrc.passing.json — the same default the
# GitLab CI template uses. Only available when Drupal is installed and
# core/node_modules exists (i.e. yarn/npm install has been run in core).
CORE_ESLINTRC="${DDEV_APPROOT}/${DDEV_DOCROOT}/core/.eslintrc.passing.json"
CORE_NODE_MODULES="${DDEV_APPROOT}/${DDEV_DOCROOT}/core/node_modules"
if [ -f "${CORE_ESLINTRC}" ] && [ -d "${CORE_NODE_MODULES}" ]; then
  eslint --no-eslintrc -c "${CORE_ESLINTRC}" "$@"
  exit $?
fi

# Priority 3: bundled fallback config (globally installed plugins).
eslint --no-eslintrc -c /mnt/ddev_config/module-developer/config/.eslintrc.json "$@"
