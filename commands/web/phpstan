#!/usr/bin/env bash
#ddev-generated

## Description: Run PHPStan static analysis with the Drupal extension
## Usage: phpstan [subcommand] [flags] [path]
## Example: "ddev phpstan analyse web/modules/custom/mymodule"
## ExecRaw: true
## HostWorkingDir: true

# If the project provides its own phpstan config, use it as-is.
# The GitLab CI Docker image pre-installs mglaman/phpstan-drupal, so the
# template's phpstan.neon does not reference it. If your project-level
# phpstan.neon also omits it, add the extension include yourself or rely
# on this command's auto-injection below.
for config in phpstan.neon phpstan.neon.dist phpstan.dist.neon; do
  if [ -f "${DDEV_APPROOT}/${config}" ]; then
    exec phpstan "$@"
  fi
done

# No project config found. Build a temporary neon that:
#  1. Includes the mglaman/phpstan-drupal extension (pre-installed in the
#     DDEV web container; in CI this comes from the Docker image instead).
#  2. Includes the bundled default config (level, fileExtensions, ignores).
#  3. Sets drupal_root to the actual DDEV docroot path.
DRUPAL_ROOT="${DDEV_APPROOT}/${DDEV_DOCROOT}"
MGLAMAN_EXT="/usr/local/composer/vendor/mglaman/phpstan-drupal/extension.neon"
MGLAMAN_RULES="/usr/local/composer/vendor/mglaman/phpstan-drupal/rules.neon"

TMPCONFIG=$(mktemp /tmp/phpstan-XXXXXX.neon)
cat > "${TMPCONFIG}" <<EOF
includes:
  - ${MGLAMAN_EXT}
  - ${MGLAMAN_RULES}
  - /mnt/ddev_config/module-developer/config/phpstan.neon

parameters:
  drupal:
    drupal_root: ${DRUPAL_ROOT}
EOF

phpstan --configuration="${TMPCONFIG}" "$@"
EXIT_CODE=$?
rm -f "${TMPCONFIG}"
exit ${EXIT_CODE}
