#!/usr/bin/env bash
#ddev-generated

## Description: Run Stylelint for CSS/SCSS validation (Drupal standards)
## Usage: stylelint [flags] [pattern]
## Example: "ddev stylelint './**/*.css'"
## ExecRaw: true
## HostWorkingDir: true

WEB_ROOT="${DDEV_DOCROOT:-web}"

# Binary resolution: web/core/node_modules first, then project-local, then global.
STYLELINT="${DDEV_APPROOT}/${WEB_ROOT}/core/node_modules/.bin/stylelint"
if [ ! -x "${STYLELINT}" ]; then
  STYLELINT="${DDEV_APPROOT}/node_modules/.bin/stylelint"
  if [ ! -x "${STYLELINT}" ]; then
    STYLELINT="stylelint"
  fi
fi

# Parse _STYLELINT_EXTRA from .gitlab-ci.yml if present.
if [ -f ".gitlab-ci.yml" ]; then
  value=$(grep -m1 "^\s*_STYLELINT_EXTRA:" ".gitlab-ci.yml" | sed -E "s/^\s*_STYLELINT_EXTRA:\s*//" | tr -d "'\"")
  if [ -n "${value}" ]; then
    export _STYLELINT_EXTRA="${value}"
  fi
fi

# Config detection: match CI behaviour — if a local stylelint config exists in the
# current directory, pass no --config flag; otherwise use core's config, falling back
# to the bundled default if core/node_modules isn't installed.
FOUND_LOCAL_CONFIG=false
for cfg in .stylelintrc .stylelintrc.json .stylelintrc.yaml .stylelintrc.yml \
           .stylelintrc.js .stylelintrc.cjs stylelint.config.js stylelint.config.cjs; do
  if [ -f "./${cfg}" ]; then
    FOUND_LOCAL_CONFIG=true
    break
  fi
done

STYLELINT_CONFIG=""
if [ "${FOUND_LOCAL_CONFIG}" = "false" ]; then
  CORE_STYLELINTRC="${DDEV_APPROOT}/${WEB_ROOT}/core/.stylelintrc.json"
  CORE_NODE_MODULES="${DDEV_APPROOT}/${WEB_ROOT}/core/node_modules"
  if [ -f "${CORE_STYLELINTRC}" ] && [ -d "${CORE_NODE_MODULES}" ]; then
    STYLELINT_CONFIG="--config ${CORE_STYLELINTRC}"
  else
    STYLELINT_CONFIG="--config ${DDEV_APPROOT}/.ddev/module-developer/config/.stylelintrc.json"
  fi
fi

# Default to the CI file glob when no arguments are given. Quoted so stylelint's
# own glob library handles ** recursively (bash without globstar would only expand
# one level deep).
if [ "$#" -eq 0 ]; then
  set -- './**/*.css'
fi

# shellcheck disable=SC2086
exec "${STYLELINT}" --allow-empty-input --ignore-path ./.stylelintignore ${STYLELINT_CONFIG} "$@" --formatter verbose --color ${_STYLELINT_EXTRA}
