#!/usr/bin/env bash
#ddev-generated

## Description: Run PHP Code Beautifier and Fixer (auto-fix phpcs violations)
## Usage: phpcbf [flags] [path]
## Example: "ddev phpcbf web/modules/custom/mymodule"
## ExecRaw: true
## HostWorkingDir: true
## MutagenSync: true

# Prefer the project-local phpcbf (same binary CI uses via $COMPOSER_BIN_DIR).
# Fall back to the globally installed binary if the project doesn't vendor it.
PHPCBF="${DDEV_APPROOT}/vendor/bin/phpcbf"
if [ ! -x "${PHPCBF}" ]; then
  PHPCBF="phpcbf"
fi

# shellcheck source=../../module-developer/lib/init.sh
source /mnt/ddev_config/module-developer/lib/init.sh

# Default to the current directory when no path is given.
if [ "$#" -eq 0 ]; then
  set -- .
fi

# Use project-level config if present at the project root.
for config in phpcs.xml phpcs.xml.dist .phpcs.xml; do
  if [ -f "${DDEV_APPROOT}/${config}" ]; then
    exec "${PHPCBF}" "$@"
  fi
done

# No project-level config found; download the Drupal GitLab Templates default
# so local checks match what the Drupal CI pipeline enforces.
curl -fsSL -o "${DDEV_APPROOT}/phpcs.xml.dist" \
  https://git.drupalcode.org/project/gitlab_templates/-/raw/default-ref/assets/phpcs.xml.dist

exec "${PHPCBF}" "$@"
