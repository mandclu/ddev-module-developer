#!/usr/bin/env bash
#ddev-generated

## Description: Run Drupal Rector for automated deprecation fixes and code upgrades
## Usage: rector [subcommand] [flags] [path]
## Example: "ddev rector process web/modules/custom/mymodule --dry-run"
## ExecRaw: true
## HostWorkingDir: true
## MutagenSync: true

# If the project provides its own rector config, use it as-is.
for config in rector.php rector.php.dist; do
  if [ -f "${DDEV_APPROOT}/${config}" ]; then
    exec rector "$@"
  fi
done

# No project config found. Generate a temporary rector.php that targets
# custom modules and applies all available Drupal upgrade sets.
TMPCONFIG=$(mktemp /tmp/rector-XXXXXX.php)
cat > "${TMPCONFIG}" <<'EOF'
<?php

declare(strict_types=1);

use DrupalRector\Set\Drupal9SetList;
use DrupalRector\Set\Drupal10SetList;
use DrupalRector\Set\Drupal11SetList;
use Rector\Config\RectorConfig;

return RectorConfig::configure()
    ->withPaths([
        '/var/www/html/web/modules/custom',
    ])
    ->withSets([
        Drupal9SetList::DRUPAL_9,
        Drupal10SetList::DRUPAL_10,
        Drupal11SetList::DRUPAL_11,
    ]);
EOF

echo "Note: No rector.php found in project root."
echo "Using auto-generated config targeting web/modules/custom."
echo "Create a rector.php in your project root to customise paths and rule sets."
echo ""

rector --config="${TMPCONFIG}" "$@"
EXIT_CODE=$?
rm -f "${TMPCONFIG}"
exit ${EXIT_CODE}
